<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-screen setup form for first-boot configuration.
  Designed for D-pad navigation: explicit nextFocusDown/Up chains
  ensure arrow keys move focus in the expected order on TV remotes.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06060A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="72dp"
        android:paddingBottom="56dp"
        android:paddingHorizontal="48dp">

        <!-- ── Wordmark ───────────────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXVISION"
            android:fontFamily="serif"
            android:textSize="32sp"
            android:textColor="#C9A84C"
            android:letterSpacing="0.25"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="First-time Setup"
            android:textSize="15sp"
            android:textColor="#5A5A6A"
            android:layout_marginBottom="52dp" />

        <!-- ── Form card ──────────────────────────────────────────────── -->

        <LinearLayout
            android:layout_width="600dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#11111A"
            android:padding="44dp">

            <!-- IP label + field -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVER IP ADDRESS"
                android:textSize="11sp"
                android:textColor="#C9A84C"
                android:letterSpacing="0.15"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etIp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="192.168.1.100"
                android:textSize="22sp"
                android:textColor="#F0F0F8"
                android:textColorHint="#383848"
                android:background="@drawable/field_bg"
                android:paddingHorizontal="16dp"
                android:inputType="textNoSuggestions"
                android:imeOptions="actionNext"
                android:focusable="true"
                android:singleLine="true"
                android:nextFocusDown="@id/etPort" />

            <!-- Port label + field -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVER PORT"
                android:textSize="11sp"
                android:textColor="#C9A84C"
                android:letterSpacing="0.15"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="5000"
                android:textSize="22sp"
                android:textColor="#F0F0F8"
                android:textColorHint="#383848"
                android:background="@drawable/field_bg"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:imeOptions="actionDone"
                android:focusable="true"
                android:singleLine="true"
                android:nextFocusUp="@id/etIp"
                android:nextFocusDown="@id/btnSave" />

            <!-- Save button -->

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="36dp"
                android:text="Save &amp; Connect"
                android:textSize="18sp"
                android:textColor="#06060A"
                android:background="@drawable/btn_primary_bg"
                android:focusable="true"
                android:nextFocusUp="@id/etPort" />

            <!-- Validation error -->

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text=""
                android:textSize="14sp"
                android:textColor="#E84855"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── ADB hint for IT staff ──────────────────────────────────── -->

        <TextView
            android:id="@+id/tvAdbHint"
            android:layout_width="600dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:textSize="12sp"
            android:textColor="#383848"
            android:gravity="center"
            android:lineSpacingMultiplier="1.6" />

    </LinearLayout>
</ScrollView>
