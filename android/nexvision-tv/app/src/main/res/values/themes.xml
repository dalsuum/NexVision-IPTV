<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      NoActionBar + black window background.
      Leanback requires a Theme.AppCompat or Theme.Leanback descendant.
    -->
    <style name="Theme.NexVisionTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
