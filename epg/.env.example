# /opt/nexvision/epg/.env.example
#
# EPG Service Configuration
# Copy to .env and fill in your values (NEVER commit with real secrets!)

# EPG Grabber Service Settings
EPG_SERVICE_URL=http://localhost:3000
EPG_FETCH_TIMEOUT=30
EPG_SYNC_INTERVAL_MINUTES=360
GUIDE_XML_OUTPUT=/opt/nexvision/epg/public/guide.xml

# Optional: EPG Source Authentication (if required)
# EPG_AUTH_USER=username
# EPG_AUTH_PASSWORD=password

# Optional: HTTP Proxy (if needed to reach EPG sources)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# Logging
LOG_LEVEL=info
