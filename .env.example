# /opt/nexvision/.env.example
# 
# This is a TEMPLATE file. Copy to .env and fill in your actual values.
# NEVER commit .env with real secrets to version control!
#
# To use: cp .env.example .env && nano .env

# ═════════════════════════════════════════════════════════════════════════════
# Database Configuration
# ═════════════════════════════════════════════════════════════════════════════

# Use SQLite (0) or MySQL (1)
USE_MYSQL=0

# MySQL settings (if USE_MYSQL=1)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nexvision
MYSQL_PASSWORD=your_secure_password_here
MYSQL_DB=nexvision
MYSQL_VOD_DB=nexvision_vod

# ═════════════════════════════════════════════════════════════════════════════
# Cache & Session Storage
# ═════════════════════════════════════════════════════════════════════════════

# Redis URL (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# ═════════════════════════════════════════════════════════════════════════════
# Web Server Configuration
# ═════════════════════════════════════════════════════════════════════════════

# Nginx X-Accel support for efficient file serving
USE_X_ACCEL=1

# Gunicorn worker count (production: CPU_count * 2 + 1)
GUNICORN_WORKERS=5

# ═════════════════════════════════════════════════════════════════════════════
# Flask Application
# ═════════════════════════════════════════════════════════════════════════════

# Environment: development, testing, production
FLASK_ENV=production

# Secret key for session encryption (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_very_long_random_secret_key_here_change_this

# VOD API Key for accessing VOD endpoints
VOD_API_KEY=your_vod_api_key_here

# ═════════════════════════════════════════════════════════════════════════════
# System User Credentials (for room API)
# ═════════════════════════════════════════════════════════════════════════════

# Main admin user
OS_USER=admin
PASSWORD=your_admin_password_here

# System service user
OS_USER=nexvision
PASSWORD=your_service_password_here

# ═════════════════════════════════════════════════════════════════════════════
# VOD Storage Backend Configuration
# ═════════════════════════════════════════════════════════════════════════════

# Options: local, nas, s3, azure, gcs
STORAGE_BACKEND=local
VOD_DATA_DIR=/opt/nexvision/vod/data

# ─── LOCAL STORAGE (default, no additional config needed) ─────────────────
# STORAGE_BACKEND=local
# VOD_DATA_DIR=./vod/data

# ─── NAS (Network Attached Storage) ────────────────────────────────────────
# STORAGE_BACKEND=nas
# NAS_MOUNT=/mnt/nas/vod
# NAS_USER=username
# NAS_PASSWORD=password

# ─── AWS S3 + CloudFront ──────────────────────────────────────────────────
# STORAGE_BACKEND=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY=AKIA...
# AWS_SECRET_KEY=...
# S3_BUCKET_UPLOADS=nexvision-uploads
# S3_BUCKET_HLS=nexvision-hls
# CLOUDFRONT_URL=https://d123.cloudfront.net

# ─── AZURE BLOB STORAGE ───────────────────────────────────────────────────
# STORAGE_BACKEND=azure
# AZURE_STORAGE_ACCOUNT=mystorageaccount
# AZURE_STORAGE_KEY=...
# AZURE_CDN_URL=https://mycdn.azureedge.net

# ─── GOOGLE CLOUD STORAGE ────────────────────────────────────────────────
# STORAGE_BACKEND=gcs
# GCP_PROJECT_ID=my-project
# GCS_BUCKET=nexvision-vod
# GCS_CREDENTIALS_JSON=/path/to/service-account-key.json

# ═════════════════════════════════════════════════════════════════════════════
# EPG Configuration
# ═════════════════════════════════════════════════════════════════════════════

# EPG auto-sync
EPG_AUTO_SYNC=enabled
EPG_SYNC_INTERVAL_HOURS=6
EPG_AUTO_URL=http://localhost:3000/guide.xml

# ═════════════════════════════════════════════════════════════════════════════
# Logging
# ═════════════════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
