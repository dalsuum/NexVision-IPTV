MYSQL_DB=nexvision
MYSQL_VOD_DB=nexvision_vod

# Redis
REDIS_URL=redis://localhost:6379/0

# Nginx X-Accel
USE_X_ACCEL=1

# Gunicorn
GUNICORN_WORKERS=5

# Application
FLASK_ENV=production
SECRET_KEY=20b0f465d3433bce8abe442d220da78d7867aabece59a6e61bb50ac1caf1ad45
VOD_API_KEY=9d5b5bf30a9302ec0921429182ed397340b1f7685e44d3b0

#OS's User
OS_USER=admin
PASSWORD=NexVis!0n
OS_USER=nexvision
PASSWORD=NexVis!0n
# ═════════════════════════════════════════════════════════════════════════════
# VOD STORAGE BACKENDS (NexVision v9.0+)
# ═════════════════════════════════════════════════════════════════════════════

# Options: local, nas, s3, azure, gcs
STORAGE_BACKEND=local
VOD_DATA_DIR=/opt/nexvision/vod_data

# ─── LOCAL STORAGE (default, no config needed) ─────────────────────────────
# VOD_DATA_DIR=./vod_data

# ─── NAS (Network Attached Storage) ────────────────────────────────────────
# STORAGE_BACKEND=nas
# NAS_MOUNT=/mnt/nas/vod

# ─── AWS S3 + CloudFront ──────────────────────────────────────────────────
# STORAGE_BACKEND=s3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY=AKIA...
# AWS_SECRET_KEY=...
# S3_BUCKET_UPLOADS=nexvision-uploads
# S3_BUCKET_HLS=nexvision-hls
# CLOUDFRONT_URL=https://d123.cloudfront.net

# ─── AZURE BLOB STORAGE ───────────────────────────────────────────────────
# STORAGE_BACKEND=azure
# AZURE_STORAGE_ACCOUNT=mystorageaccount
# AZURE_STORAGE_KEY=...
# AZURE_CDN_URL=https://mycdn.azureedge.net

# ─── GOOGLE CLOUD STORAGE ────────────────────────────────────────────────
# STORAGE_BACKEND=gcs
# GCP_PROJECT_ID=my-project
# GCS_BUCKET=nexvision-vod
